# FlightDeck environment configuration
# Copy to `.env` and fill in your values

# --- App ---
FLIGHTDECK_ENV=dev                          # dev | test | prod
FLIGHTDECK_API_HOST=0.0.0.0
FLIGHTDECK_API_PORT=8001
FLIGHTDECK_LOG_LEVEL=INFO

# --- Database ---
# Async SQLAlchemy URL (asyncpg driver)
# Note: port 5434 to avoid conflict with the primary Postgres on 5432
FLIGHTDECK_DATABASE_URL=postgresql+asyncpg://flightdeck:flightdeck@localhost:5434/flightdeck

# --- Redis (cache + Celery broker) ---
# Note: port 6381 to avoid conflict with the primary Redis on 6379
FLIGHTDECK_REDIS_URL=redis://localhost:6381/0

# --- External APIs ---
# Amadeus Self-Service: https://developers.amadeus.com/
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
# Use test environment by default; set to https://api.amadeus.com for production
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Kiwi Tequila: https://tequila.kiwi.com/
KIWI_API_KEY=

# SerpAPI (Google Flights): https://serpapi.com/
SERPAPI_API_KEY=
